{
  "name": "eslint-plugin-tailwind-canonical-classes",
  "version": "1.2.0",
  "description": "ESLint plugin to enforce canonical Tailwind CSS class names using Tailwind CSS v4's canonicalization API",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./rule": {
      "types": "./lib/rules/tailwind-canonical-classes.d.ts",
      "default": "./lib/rules/tailwind-canonical-classes.js"
    }
  },
  "files": [
    "lib"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "tailwind",
    "tailwindcss",
    "canonical",
    "lint",
    "css"
  ],
  "author": "Maisonnat Maxence <maisonnatmax@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaisonnatM/eslint-plugin-tailwind-canonical-classes.git"
  },
  "bugs": {
    "url": "https://github.com/MaisonnatM/eslint-plugin-tailwind-canonical-classes/issues"
  },
  "homepage": "https://github.com/MaisonnatM/eslint-plugin-tailwind-canonical-classes#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "npm run build && vitest",
    "test:run": "npm run build && vitest run",
    "prepublishOnly": "npm run build",
    "release": "semantic-release"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "dependencies": {
    "@tailwindcss/node": "^4.0.0",
    "synckit": "^0.9.3"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^12.0.1",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "semantic-release": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.16"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
