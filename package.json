{
  "name": "eslint-plugin-tailwind-canonical-classes",
  "version": "1.0.8",
  "description": "ESLint plugin to enforce canonical Tailwind CSS class names using Tailwind CSS v4's canonicalization API",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./rule": {
      "types": "./lib/tailwind-canonical-classes.d.ts",
      "default": "./lib/tailwind-canonical-classes.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib"
  ],
  "keywords": [
    "eslint",
    "eslint-plugin",
    "tailwind",
    "tailwindcss",
    "canonical",
    "lint",
    "css"
  ],
  "author": "Maisonnat Maxence <maisonnatmax@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaisonnatM/eslint-plugin-tailwind-canonical-classes.git"
  },
  "bugs": {
    "url": "https://github.com/MaisonnatM/eslint-plugin-tailwind-canonical-classes/issues"
  },
  "homepage": "https://github.com/MaisonnatM/eslint-plugin-tailwind-canonical-classes#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "release": "semantic-release"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "dependencies": {
    "@tailwindcss/node": "^4.0.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "semantic-release": "^24.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^12.0.1"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  }
}
